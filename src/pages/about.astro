---
import Base from "../layouts/Base.astro";

const pageTitle = "About Me";

const identity = {
  firstName: "Jia-Rou",
  country: "Tellus",
  occupation: "Unemployed",
  hobbies: ["art", "go", "coding"],
};

const pokemon = ["Gogo", "Eevee", "Boba", "Mr Cinnamon"];

const happy = true;
const finished = false;
const goal = 3;

const pokeColor = "crimson";
---

<Base>
  <h1>{pageTitle}</h1>
  <h2>... and my new Astro site!</h2>
  <p>
    I am working through Astro's introductory tutorial. This is the second page
    on my website, and it's the third (T-T) one I built myself!
  </p>
  <p>Here are a few facts about me:</p>
  <ul>
    <li>My name is {identity.firstName}.</li>
    <li>
      I live in {identity.country} and I work as a {identity.occupation}.
    </li>
    {
      identity.hobbies.length >= 2 && (
        <li>
          Two of my hobbies are: {identity.hobbies[0]} and {identity.hobbies[1]}
        </li>
      )
    }
  </ul>
  <p>My companions are:</p>
  <ul>
    {pokemon.map((pokemon) => <li class="pokemon">{pokemon}</li>)}
  </ul>
  {happy && <p>I am happy to be learning Astro!</p>}

  {finished && <p>I finished this tutorial!</p>}

  {
    goal === 3 ? (
      <p>My goal is to finish in 3 days.</p>
    ) : (
      <p>My goal is not 3 days.</p>
    )
  }
</Base>
